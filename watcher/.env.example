# ============================================================================
# NuRock Utilities folder watcher — configuration
# ============================================================================
# Copy to .env in this same directory before running.

# --- Required ---------------------------------------------------------------
APP_URL=https://utilities.nurock.com
INTAKE_WEBHOOK_SECRET=                   # must match the value in the web app
WATCH_FOLDER=H:\Claude\Utility Invoices

# --- Optional (defaults shown) ----------------------------------------------
MOVE_ON_SUCCESS=true
MOVE_ON_FAILURE=true
STABLE_WAIT_MS=2000
RETRY_LIMIT=3
LOG_FILE=./watcher.log
