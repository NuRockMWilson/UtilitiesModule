# ============================================================================
# NuRock Utilities AP — environment
# Copy to .env.local for local development; set in Vercel for production.
# ============================================================================

# --- Supabase -----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                 # server-only; never expose

# --- Anthropic (Claude extraction) --------------------------------------
ANTHROPIC_API_KEY=
# Default Sonnet 4.5; switch to claude-opus-4-5 for hard cases.
# Do NOT put trailing comments on the same line — dotenv treats the whole
# line after `=` as the value, including the `#`.
ANTHROPIC_EXTRACTION_MODEL=claude-sonnet-4-5

# --- Email (Resend for variance inquiries) ------------------------------
RESEND_API_KEY=
VARIANCE_FROM_EMAIL=ap-utilities@nurock.com
AP_TEAM_NOTIFY_EMAIL=mwilson@nurock.com,katelyn@nurock.com

# --- Intake inbox -------------------------------------------------------
# Option A: IMAP polling of a shared mailbox
INTAKE_IMAP_HOST=
INTAKE_IMAP_USER=
INTAKE_IMAP_PASSWORD=
# Option B: Inbound webhook (SendGrid / Resend / Cloudflare)
INTAKE_WEBHOOK_SECRET=

# --- Sage integration ---------------------------------------------------
# 300 CRE: AP Import files are generated in-memory, uploaded to the
#          Supabase 'sage-exports' storage bucket, and handed to Sharon
#          as a signed download link. No filesystem path needed — the
#          entire flow runs on Vercel.
# Intacct (REST API) — fill these when migration completes
SAGE_INTACCT_COMPANY_ID=
SAGE_INTACCT_USER_ID=
SAGE_INTACCT_USER_PASSWORD=
SAGE_INTACCT_SENDER_ID=
SAGE_INTACCT_SENDER_PASSWORD=

# --- App ----------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3050
NODE_ENV=development
